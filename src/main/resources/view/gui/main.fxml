<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.arvedi.view.gui.GuiController" spacing="12" alignment="CENTER" stylesheets="@styles.css">
    <padding><Insets topRightBottomLeft="20"/></padding>

    <Label text="Counter" styleClass="title"/>
    <Label fx:id="lblCount" styleClass="big"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnDec" text="–"/>
        <Button fx:id="btnInc" text="+"/>
        <Button fx:id="btnReset" text="Reset"/>
    </HBox>
</VBox>
